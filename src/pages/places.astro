---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { placesConfig } from "../config/placesConfig";

export const prerender = true;

// 足迹数据（从配置文件读取）
const places = placesConfig.places;

// 统计数据
const cityCount = new Set(places.map((p) => p.city)).size;
const totalVisits = places.reduce((sum, p) => sum + (p.visitCount || 1), 0);
const currentYear = new Date().getFullYear();
const thisYearVisits = places.filter((p) => p.date && p.date.startsWith(String(currentYear))).length;
const totalPlaces = places.length;

// 传给客户端的配置
const amapKey = placesConfig.amapKey;
const amapSecurityCode = placesConfig.amapSecurityCode;
const mapCenter = placesConfig.center;
const mapZoom = placesConfig.zoom;
const mapStyle = placesConfig.mapStyle;
const darkMapStyle = placesConfig.darkMapStyle;
const markerColor = placesConfig.marker.color;
const markerSize = placesConfig.marker.size;
---

<MainGridLayout title="去过的地方" description="足迹地图与旅行记录">
	<div class="flex w-full flex-col gap-5">
		<!-- 统计卡片区域 -->
		<section class="card-base rounded-[var(--radius-large)] p-6">
			<h1 class="mb-2 text-3xl font-bold text-[var(--primary)]">🗺️ 去过的地方</h1>
			<p class="text-sm text-[var(--content-meta)]">在地图上标记你去过的城市，点击标记点查看足迹详情。</p>
			<div class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-4">
				<div class="life-stat-card rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-4">
					<div class="text-xs text-[var(--content-meta)]">去过城市</div>
					<div class="mt-1 text-xl font-bold">{cityCount}</div>
				</div>
				<div class="life-stat-card rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-4">
					<div class="text-xs text-[var(--content-meta)]">总到访次数</div>
					<div class="mt-1 text-xl font-bold">{totalVisits}</div>
				</div>
				<div class="life-stat-card rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-4">
					<div class="text-xs text-[var(--content-meta)]">今年出行</div>
					<div class="mt-1 text-xl font-bold">{thisYearVisits}</div>
				</div>
				<div class="life-stat-card rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-4">
					<div class="text-xs text-[var(--content-meta)]">总地点</div>
					<div class="mt-1 text-xl font-bold">{totalPlaces}</div>
				</div>
			</div>
		</section>

		<!-- 足迹地图区域 -->
		<section class="card-base rounded-[var(--radius-large)] p-6">
			<h2 class="mb-4 text-xl font-bold text-[var(--text-color)]">足迹地图</h2>
			<div id="life-map" class="h-[600px] w-full rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] overflow-hidden"></div>
			<p class="mt-2 text-xs text-[var(--content-meta)] text-center">地图由 高德地图 提供</p>
		</section>

		<!-- 地点列表区域 -->
		<section class="card-base rounded-[var(--radius-large)] p-6">
			<h2 class="mb-4 text-xl font-bold text-[var(--text-color)]">地点列表</h2>
			<div class="grid gap-3 md:grid-cols-2">
				{places.map((place) => (
					<article class="life-data-item rounded-xl border border-[var(--line-divider)] bg-[var(--card-bg)] p-4">
						<div class="flex items-start justify-between">
							<div>
								<h3 class="font-semibold">{place.province} - {place.city}</h3>
								{place.experience && <p class="mt-1 text-sm text-[var(--content-meta)]">{place.experience}</p>}
							</div>
							<div class="text-right text-sm text-[var(--content-meta)]">
								<div class="font-medium">到访 {place.visitCount || 1} 次</div>
								{place.date && <div class="text-xs">{place.date}</div>}
							</div>
						</div>
					</article>
				))}
			</div>
		</section>
	</div>
</MainGridLayout>

<script is:inline define:vars={{ amapKey, amapSecurityCode, mapCenter, mapZoom, mapStyle, darkMapStyle, markerColor, markerSize, places }}>
(function() {
	var container = document.getElementById('life-map');
	if (!container) {
		console.error('地图容器未找到');
		return;
	}

	// 设置高德地图安全密钥
	window._AMapSecurityConfig = {
		securityJsCode: amapSecurityCode,
	};

	var mapInstance = null;
	var markers = [];
	var infoWindow = null;

	function loadAMap() {
		return new Promise(function(resolve, reject) {
			if (window.AMap) {
				resolve(window.AMap);
				return;
			}
			var script = document.createElement('script');
			script.src = 'https://webapi.amap.com/maps?v=2.0&key=' + amapKey + '&plugin=AMap.Geocoder,AMap.InfoWindow';
			script.onload = function() {
				if (window.AMap) {
					resolve(window.AMap);
				} else {
					reject(new Error('高德地图加载失败'));
				}
			};
			script.onerror = function() { reject(new Error('高德地图加载失败')); };
			document.head.appendChild(script);
		});
	}

	// 根据地点名称使用高德地理编码获取经纬度
	// 优先使用 places 数组中预配置的 lng/lat，否则通过地理编码获取
	function geocodePlace(AMap, place) {
		// 优先使用硬编码坐标
		if (typeof place.lng === 'number' && typeof place.lat === 'number') {
			return Promise.resolve({ lng: place.lng, lat: place.lat });
		}
		return new Promise(function(resolve) {
			var geocoder = new AMap.Geocoder({ city: '' });
			var address = (place.province || '') + (place.city || '') + (place.district || '');
			geocoder.getLocation(address, function(status, result) {
				if (status === 'complete' && result.geocodes && result.geocodes.length > 0) {
					var lnglat = result.geocodes[0].location;
					resolve({ lng: lnglat.lng, lat: lnglat.lat });
				} else {
					console.warn('地理编码失败:', address, status);
					resolve(null);
				}
			});
		});
	}

	// 检测暗色模式
	function isDarkMode() {
		return window.matchMedia('(prefers-color-scheme: dark)').matches;
	}

	function initMap() {
		var currentContainer = document.getElementById('life-map');
		if (!currentContainer) return;

		loadAMap().then(function(AMap) {
			// 创建地图
			mapInstance = new AMap.Map(currentContainer, {
				zoom: mapZoom,
				center: mapCenter,
				mapStyle: isDarkMode() ? darkMapStyle : mapStyle,
				viewMode: '2D',
			});

			// 创建信息窗
			infoWindow = new AMap.InfoWindow({
				offset: new AMap.Pixel(0, -markerSize - 5),
				closeWhenClickMap: true,
			});

			// 对每个地点进行地理编码并添加标记
			var geocodePromises = places.map(function(place) {
				return geocodePlace(AMap, place).then(function(lnglat) {
					if (!lnglat) return null;

					// 创建标记点
					var marker = new AMap.CircleMarker({
						center: [lnglat.lng, lnglat.lat],
						radius: markerSize,
						fillColor: markerColor,
						fillOpacity: 0.8,
						strokeColor: '#fff',
						strokeWeight: 2,
						cursor: 'pointer',
						zIndex: 100,
					});

					marker.setMap(mapInstance);

					// 点击标记显示信息窗
					var content = '<div style="padding:8px;min-width:180px;">' +
						'<strong style="font-size:14px;">' + (place.province || '') + ' - ' + (place.city || '') + '</strong>' +
						(place.experience ? '<p style="margin:4px 0;font-size:12px;color:#666;">' + place.experience + '</p>' : '') +
						'<div style="font-size:12px;color:#999;">到访 ' + (place.visitCount || 1) + ' 次' +
						(place.date ? ' · ' + place.date : '') + '</div>' +
						'</div>';

					marker.on('click', function() {
						infoWindow.setContent(content);
						infoWindow.open(mapInstance, [lnglat.lng, lnglat.lat]);
					});

					markers.push(marker);
					return marker;
				});
			});

			return Promise.all(geocodePromises);
		}).then(function(results) {
			var validMarkers = results.filter(function(m) { return m !== null; });
			if (validMarkers.length > 0) {
				// 自动调整视野以包含所有标记
				mapInstance.setFitView(validMarkers, false, [60, 60, 60, 60]);
			}
		}).catch(function(err) {
			var failContainer = document.getElementById('life-map');
			if (failContainer) {
				failContainer.innerHTML = '<div class="h-full flex items-center justify-center text-[var(--content-meta)]">地图加载失败: ' + (err.message || '') + '</div>';
			}
		});
	}

	function whenReady(fn) {
		if (document.readyState === 'complete') {
			requestAnimationFrame(fn);
		} else {
			window.addEventListener('load', function() {
				requestAnimationFrame(fn);
			});
		}
	}

	whenReady(initMap);

	// 窗口大小变化时重新调整地图
	window.addEventListener('resize', function() {
		if (mapInstance) {
			mapInstance.setSize();
		}
	});

	// 暗色模式切换时重新加载地图
	var prefersDark = window.matchMedia('(prefers-color-scheme: dark)');
	function handleThemeChange() {
		if (mapInstance) {
			mapInstance.setMapStyle(isDarkMode() ? darkMapStyle : mapStyle);
		}
	}
	prefersDark.addEventListener('change', handleThemeChange);

	// Astro 页面切换后重新初始化
	document.addEventListener('astro:after-swap', function() {
		var newContainer = document.getElementById('life-map');
		if (newContainer && !mapInstance) {
			whenReady(initMap);
		}
	});
})();
</script>
